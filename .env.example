# Copie para .env.local (não commitar segredos reais).

# --- Opcional: login Google + allowlist ---
# Se AUTH_GOOGLE_ID e AUTH_GOOGLE_SECRET estiverem definidos, o app exige login
# e só aceita e-mails listados em AUTH_ALLOWED_EMAILS (separados por vírgula).
# AUTH_URL deve ser a URL pública do app (ex.: https://smarttask.seudominio.com).

AUTH_SECRET=
AUTH_URL=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_ALLOWED_EMAILS=

# --- App (já usado antes) ---
# NEXT_PUBLIC_FOCUS_DAY_MAX=3
