# Copie para .env.local (não commitar segredos reais).

# --- Opcional: senha única para acessar o app ---
# Se SMARTTASK_ACCESS_PASSWORD estiver definida, o app exige login em /login
# e usa cookie httpOnly com sessão de 30 dias (renova a cada navegação autenticada).
# Recomendado na VPS: defina também SMARTTASK_SESSION_SECRET (string longa e aleatória).

SMARTTASK_ACCESS_PASSWORD=
SMARTTASK_SESSION_SECRET=

# --- App (opcional) ---
# NEXT_PUBLIC_FOCUS_DAY_MAX=3
